---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import PersonaCard from '../components/PersonaCard.astro';
import ResourceCard from '../components/ResourceCard.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import '../styles/landing.css';

const base = import.meta.env.BASE_URL;

const faqTeaseItems = [
  {
    question: "If my coverage is 90%, why do I still have bugs in production?",
    answer: "Coverage measures which lines executed, not whether your tests would catch a bug on those lines. In our case study, 90% line coverage missed both computation bugs. Mutation testing measures what coverage cannot: would your tests actually fail if the code was wrong?",
  },
  {
    question: "Isn't property-based testing just fuzzing?",
    answer: "No. Fuzzing generates random input to find crashes. PBT declares properties (rules that must hold for all valid inputs) and uses structured generation with automatic shrinking to minimal counterexamples. PBT catches logic errors, not just crashes.",
  },
  {
    question: "How does ArchUnit help with AI-generated code specifically?",
    answer: "AI models default to the most common API in training data, not the one your team migrated to. ArchUnit converts architectural decisions into executable gates. In controlled experiments, 10/10 AI generations violated layer boundaries without ArchUnit, 0/10 with it.",
  },
];
---
<BaseLayout title="Visdom Testing">

  <!-- ============ Hero ============ -->
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__headline">
        Visdom<br />
        <span class="hero__gradient">Testing</span>
      </h1>
      <p class="hero__subtitle">
        A multi-layered testing strategy for teams shipping AI-generated code.
        When AI writes the code and the tests, who tests the tests?
      </p>
      <div class="hero__buttons">
        <a href={`${base}guide/leaders/`} class="btn btn--primary">For Leaders</a>
        <a href={`${base}reference/`} class="btn btn--outline">Technical Reference</a>
        <a href={`${base}before-after/`} class="btn btn--outline">Before / After</a>
      </div>
      <p class="hero__tagline">Part of <a href="https://virtuslab.com/services/visdom" class="hero__tagline-link">Visdom</a> &middot; VirtusLab's AI-Native SDLC</p>
    </div>
  </section>

  <!-- ============ The Problem: Dark full-width banner ============ -->
  <section class="problem-banner">
    <div class="problem-banner__inner">
      <h2 class="problem-banner__heading">The circular quality problem</h2>
      <p class="problem-banner__subtitle">AI generates both implementation and tests. Traditional metrics break down.</p>
      <div class="problem-banner__grid">
        <div class="problem-banner__card">
          <span class="problem-banner__num">01</span>
          <strong class="problem-banner__title">Circular Tests</strong>
          <p class="problem-banner__desc">Tests pass because they encode the same assumptions as the code.</p>
        </div>
        <div class="problem-banner__card">
          <span class="problem-banner__num">02</span>
          <strong class="problem-banner__title">Metric Inflation</strong>
          <p class="problem-banner__desc">90% line coverage, 0 computation bugs caught.</p>
        </div>
        <div class="problem-banner__card">
          <span class="problem-banner__num">03</span>
          <strong class="problem-banner__title">Architecture Erosion</strong>
          <p class="problem-banner__desc">AI takes the shortest path. Controllers call repositories directly.</p>
        </div>
        <div class="problem-banner__card">
          <span class="problem-banner__num">04</span>
          <strong class="problem-banner__title">API Regression</strong>
          <p class="problem-banner__desc">AI reaches for deprecated APIs from training data.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Evidence + Stats: Combined section ============ -->
  <section class="evidence-section">
    <div class="evidence-section__inner">
      <div class="evidence-section__top">
        <h2 class="section-heading">The evidence</h2>
        <p class="section-subtitle">
          Same agent, same CRUD task, 10 repetitions. The numbers speak for themselves.
        </p>
      </div>

      <div class="evidence-section__columns">
        <!-- Left: Experiment table -->
        <div class="evidence-section__primary">
          <div class="card">
            <p class="card__label">ArchUnit experiment &mdash; 10 runs each</p>
            <div class="diff-table">
              <div class="diff-table__header">
                <span></span>
                <span class="diff-table__col-head">Without ArchUnit</span>
                <span class="diff-table__col-head diff-table__col-head--vt">With ArchUnit</span>
              </div>
              <div class="diff-table__row">
                <span class="diff-table__label">Layer bypass</span>
                <span>10/10 violations</span>
                <span class="diff-table__vt">0/10 violations</span>
              </div>
              <div class="diff-table__row">
                <span class="diff-table__label">Field injection</span>
                <span>1/10</span>
                <span class="diff-table__vt">0/10</span>
              </div>
              <div class="diff-table__row">
                <span class="diff-table__label">Generic exception</span>
                <span>1/10</span>
                <span class="diff-table__vt">0/10</span>
              </div>
              <div class="diff-table__row">
                <span class="diff-table__label">Compilation required?</span>
                <span>Yes (violations compile)</span>
                <span class="diff-table__vt">Violations fail the build</span>
              </div>
            </div>
          </div>

          <div class="card" style="margin-top: 16px;">
            <p class="card__label">PBT vs Traditional &mdash; metric comparison</p>
            <div class="experiment-table-wrap">
              <table class="experiment-table">
                <thead>
                  <tr>
                    <th>Metric</th>
                    <th>Traditional</th>
                    <th>PBT</th>
                    <th>Combined</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>Line coverage</strong></td>
                    <td>90%</td>
                    <td>80%</td>
                    <td class="experiment-table__score">90%</td>
                  </tr>
                  <tr>
                    <td><strong>Mutation score</strong></td>
                    <td>73%</td>
                    <td>55%</td>
                    <td class="experiment-table__score">73%</td>
                  </tr>
                  <tr>
                    <td><strong>Bugs found</strong></td>
                    <td>0/2</td>
                    <td>2/2</td>
                    <td class="experiment-table__score">2/2</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Right: Stats stacked vertically -->
        <div class="evidence-section__sidebar">
          <StatCard
            value="90%"
            label="line coverage while missing both computation bugs in a pricing module"
            source="VirtusLab PBT Case Study"
            color="red"
          />
          <StatCard
            value="84%"
            label="of pass-to-fail test transitions are flaky, not real regressions"
            source="Micco, ICST 2017 (Google)"
            color="amber"
          />
          <StatCard
            value="1.7x"
            label="more issues in AI-generated PRs than human-written ones"
            source="CodeRabbit (2025)"
            color="blue"
          />
          <StatCard
            value="73%"
            label="acceptance rate for AI-generated mutation tests"
            source="Meta ACH (2025)"
            color="purple"
          />
        </div>
      </div>

      <div class="evidence-section__insight">
        <strong>The critical insight:</strong> By every standard metric, the traditional suite looked better.
        PBT found both computation bugs &mdash; early rounding of discount rate and wrong rounding mode on VAT &mdash;
        that 90% line coverage and 16 hand-written tests missed entirely.
      </div>
    </div>
  </section>

  <!-- ============ Personas: Horizontal cards ============ -->
  <section class="persona-section">
    <div class="persona-section__inner">
      <h2 class="section-heading">Sound familiar?</h2>
      <p class="section-subtitle">
        Real patterns from enterprise teams adopting AI-assisted development.
      </p>

      <div class="persona-grid">
        <PersonaCard name="Your Engineering Manager" role="Katja's problem" color="blue">
          <p>"Our test suite takes 45 minutes and 84% of the failures are flaky. Developers don't trust CI anymore."</p>
        </PersonaCard>

        <PersonaCard name="Your QA Lead" role="Tomek's problem" color="purple">
          <p>"We hit 90% coverage then three pricing bugs shipped. The AI copied the implementation logic into the assertions."</p>
        </PersonaCard>

        <PersonaCard name="Your Senior Developer" role="Priya's problem" color="amber">
          <p>"Copilot bypassed the service layer, used RestTemplate instead of RestClient, and the tests mocked everything."</p>
        </PersonaCard>
      </div>
    </div>
  </section>

  <!-- ============ Testing Strategies: Full-width 4-col grid ============ -->
  <section class="strategies-section">
    <div class="strategies-section__inner">
      <h2 class="section-heading">No single shape fits all</h2>
      <p class="section-subtitle">
        The right testing strategy depends on your architecture.
        Visdom Testing adapts to your stack.
      </p>
      <div class="strategies-grid">
        <a href={`${base}reference/architecture/`} class="strategies-grid__card strategies-grid__card--pyramid">
          <span class="strategies-grid__icon">&#9650;</span>
          <h3 class="strategies-grid__title">Pyramid</h3>
          <p class="strategies-grid__desc">Classic. Many unit, fewer integration, minimal E2E. Best for monoliths.</p>
        </a>
        <a href={`${base}reference/architecture/`} class="strategies-grid__card strategies-grid__card--trophy">
          <span class="strategies-grid__icon">&#9733;</span>
          <h3 class="strategies-grid__title">Trophy</h3>
          <p class="strategies-grid__desc">Integration-heavy. Kent C. Dodds model. Best for modern frontend.</p>
        </a>
        <a href={`${base}reference/architecture/`} class="strategies-grid__card strategies-grid__card--honeycomb">
          <span class="strategies-grid__icon">&#11042;</span>
          <h3 class="strategies-grid__title">Honeycomb</h3>
          <p class="strategies-grid__desc">Spotify model. Contract-focused. Best for microservices.</p>
        </a>
        <a href={`${base}reference/architecture/`} class="strategies-grid__card strategies-grid__card--diamond">
          <span class="strategies-grid__icon">&#9670;</span>
          <h3 class="strategies-grid__title">Diamond</h3>
          <p class="strategies-grid__desc">Wide integration layer. Best for domain services.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ Resources + FAQ: Two-column layout ============ -->
  <section class="resources-faq-section">
    <div class="resources-faq-section__inner">
      <div class="resources-faq-section__left">
        <h2 class="section-heading" style="text-align: left;">Go deeper</h2>

        <div class="resources-stack">
          <ResourceCard
            title="Before / After Scenarios"
            description="4 scenarios showing what changes when Visdom Testing is deployed."
            href={`${base}before-after/`}
            tag="SCENARIOS"
            tagColor="blue"
          />
          <ResourceCard
            title="Technical Reference"
            description="Full architecture, layer docs, configuration, metrics framework."
            href={`${base}reference/`}
            tag="REFERENCE"
            tagColor="purple"
          />
          <ResourceCard
            title="Architecture Testing"
            description="ArchUnit experiment: 10/10 violations without, 0/10 with."
            href={`${base}reference/layers/architecture-testing/`}
            tag="LAYER 0"
            tagColor="blue"
          />
        </div>

        <h3 class="section-subheading" style="text-align: left; margin-top: 2rem;">From the field</h3>
        <div class="resources-stack resources-stack--2col">
          <ResourceCard
            title="DORA 2025: AI Adoption Impact"
            description="90% AI adoption correlates with 9% bug rate increase and 91% more code review time."
            href="https://dora.dev/research/2025/dora-report/"
            tag="RESEARCH"
            tagColor="red"
            source="Google DORA"
          />
          <ResourceCard
            title="Meta: LLM-Powered Bug Catchers"
            description="73% acceptance rate. 49% of tests caught faults invisible to line coverage."
            href="https://engineering.fb.com/2025/02/05/security/revolutionizing-software-testing-llm-powered-bug-catchers-meta-ach/"
            tag="RESEARCH"
            tagColor="purple"
            source="Meta Engineering"
          />
          <ResourceCard
            title="PBT Finds 50x More Mutations"
            description="Each property-based test finds ~50x as many mutations as the average unit test."
            href="https://cseweb.ucsd.edu/~mcoblenz/assets/pdf/OOPSLA_2025_PBT.pdf"
            tag="RESEARCH"
            tagColor="blue"
            source="OOPSLA 2025"
          />
          <ResourceCard
            title="AI Code: 1.7x More Issues"
            description="AI PRs average 10.83 issues vs 6.45 for human PRs across 470 pull requests."
            href="https://www.coderabbit.ai/blog/state-of-ai-vs-human-code-generation-report"
            tag="RESEARCH"
            tagColor="amber"
            source="CodeRabbit (2025)"
          />
          <ResourceCard
            title="Atlassian: AI Mutation Coverage"
            description="56% to 80% mutation coverage on real Jira projects."
            href="https://www.atlassian.com/blog/developer/automating-mutation-coverage-with-ai"
            tag="INDUSTRY"
            tagColor="blue"
            source="Atlassian"
          />
          <ResourceCard
            title="Stanford: AI Makes Code Less Secure"
            description="Developers with AI assistants wrote less secure code but believed it was more secure."
            href="https://dl.acm.org/doi/10.1145/3576915.3623157"
            tag="RESEARCH"
            tagColor="red"
            source="Stanford / CCS 2023"
          />
          <ResourceCard
            title="Google: Flaky Tests at Scale"
            description="84% of pass-to-fail transitions are flaky. 1.5% of all executions report flakiness."
            href="https://testing.googleblog.com/2016/05/flaky-tests-at-google-and-how-we.html"
            tag="RESEARCH"
            tagColor="purple"
            source="Micco, ICST 2017"
          />
          <ResourceCard
            title="Endor Labs: AI Design Flaws"
            description="15/20 AI completions had design flaws. 12/20 exhibited design pattern drift."
            href="https://www.endorlabs.com/learn/design-flaws-in-ai-generated-code"
            tag="RESEARCH"
            tagColor="amber"
            source="Endor Labs (2025)"
          />
        </div>
      </div>

      <div class="resources-faq-section__right">
        <h2 class="section-heading" style="text-align: left;">FAQ</h2>
        <FaqAccordion items={faqTeaseItems} />
        <div style="margin-top: 1rem;">
          <a href={`${base}faq/`} class="btn btn--outline">See all questions &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Part of Visdom: Horizontal strip ============ -->
  <section class="visdom-strip">
    <div class="visdom-strip__inner">
      <div class="visdom-strip__label">
        <span class="kicker" style="margin-bottom: 0;">Part of Visdom</span>
        <p class="visdom-strip__desc">VirtusLab's AI-Native SDLC</p>
      </div>
      <div class="visdom-strip__items">
        <a href="https://github.com/virtuslab/vidia" class="visdom-strip__item">
          <span class="visdom-strip__item-name">ViDIA</span>
          <span class="visdom-strip__item-role">Context Fabric</span>
        </a>
        <div class="visdom-strip__item">
          <span class="visdom-strip__item-name">Fast Feedback</span>
          <span class="visdom-strip__item-role">Machine-Speed CI</span>
        </div>
        <a href="https://virtuslab.github.io/visdom-code-review/" class="visdom-strip__item">
          <span class="visdom-strip__item-name">VCR</span>
          <span class="visdom-strip__item-role">Code Review</span>
        </a>
        <a href={`${base}`} class="visdom-strip__item visdom-strip__item--active">
          <span class="visdom-strip__item-name">Testing</span>
          <span class="visdom-strip__item-role">Quality Assurance</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta-section">
    <div class="cta-section__inner">
      <h2 class="cta-section__heading">
        Read the<br /><span class="hero__gradient">full reference</span>
      </h2>
      <p class="cta-section__subtitle">
        Architecture, layer docs, metrics framework, and the evidence behind each technique.
      </p>
      <div class="hero__buttons">
        <a href={`${base}reference/`} class="btn btn--primary">Technical Reference</a>
        <a href={`${base}before-after/`} class="btn btn--outline">Before / After Scenarios</a>
      </div>
    </div>
  </section>

</BaseLayout>
